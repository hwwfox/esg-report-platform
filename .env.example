APP_ENV=local
APP_NAME=esg-report-platform
APP_PORT=8080
WEB_PORT=3000

DATABASE_URL=postgresql+psycopg://esg_user:esg_password@localhost:5432/esg_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=esg_dev
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=esg_password

REDIS_URL=redis://localhost:6379/0

OBJECT_STORAGE_TYPE=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET_FILES=esg-files
OBJECT_STORAGE_BUCKET_EXPORTS=esg-exports
OBJECT_STORAGE_BUCKET_TEMP=esg-temp

JWT_SECRET=local_dev_jwt_secret_change_me
JWT_EXPIRES_IN=7200

AI_PROVIDER=mock
AI_API_BASE_URL=http://localhost:9002
AI_API_KEY=local_mock_key
AI_DEFAULT_MODEL=mock-model
AI_ENABLE_COST_TRACKING=true

LOG_LEVEL=DEBUG
CORS_ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=100
